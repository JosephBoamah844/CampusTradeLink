    "@react-navigation/native-stack": "^6.9.17",
    "@reduxjs/toolkit": "^1.9.7",
    "axios": "^1.6.0",
    "expo": "~49.0.15",
    "expo-camera": "~13.4.4",
    "expo-constants": "~14.4.2",
    "expo-dev-client": "~2.4.12",
    "expo-font": "~11.4.0",
    "expo-image": "~1.3.5",
