# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:4000/api
EXPO_PUBLIC_WS_URL=http://localhost:4000

# App Configuration
EXPO_PUBLIC_APP_NAME=Campus Trade Link
EXPO_PUBLIC_APP_VERSION=1.0.0

# Upload Configuration
EXPO_PUBLIC_MAX_FILE_SIZE=5242880
EXPO_PUBLIC_MAX_IMAGES_PER_POST=4
EXPO_PUBLIC_MAX_IMAGES_PER_PRODUCT=6

# Student Email Domain
EXPO_PUBLIC_STUDENT_EMAIL_DOMAIN=@st.ug.edu.gh

# Feature Flags
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_CAMERA=true
EXPO_PUBLIC_ENABLE_ANALYTICS=false